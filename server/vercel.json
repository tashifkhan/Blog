{
	"version": 2,
	"builds": [
		{
			"src": "./app.py",
			"use": "@vercel/python",
			"config": {
				"includeFiles": [
					"../src/blogs/**/*.md",
					"../src/blogs/**/*.mdx",
					"src/blogs/**/*.md",
					"src/blogs/**/*.mdx"
				]
			}
		}
	],
	"routes": [
		{
			"src": "/(.*)",
			"dest": "/app.py"
		}
	]
}
